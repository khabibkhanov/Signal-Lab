{
	"name": "signal-lab-backend",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "nest build",
		"start": "nest start",
		"start:dev": "ts-node-dev --poll --respawn --transpile-only src/main.ts",
		"start:prod": "node dist/main.js",
		"prisma:generate": "prisma generate --config prisma.config.ts",
		"prisma:migrate": "prisma migrate deploy --config prisma.config.ts"
	},
	"dependencies": {
		"@nestjs/common": "^10.4.8",
		"@nestjs/core": "^10.4.8",
		"@nestjs/platform-express": "^10.4.8",
		"@prisma/adapter-pg": "^7.7.0",
		"@nestjs/swagger": "^7.4.2",
		"@prisma/client": "^7.7.0",
		"@sentry/node": "^8.30.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"pg": "^8.13.1",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"swagger-ui-express": "^5.0.1"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.4.8",
		"@nestjs/schematics": "^10.1.4",
		"@nestjs/testing": "^10.4.8",
		"@types/express": "^4.17.21",
		"@types/node": "^20.14.10",
		"@types/pg": "^8.11.10",
		"prisma": "^7.7.0",
		"ts-node": "^10.9.2",
		"ts-node-dev": "^2.0.0",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.5.4"
	}
}
