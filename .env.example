# PostgreSQL
POSTGRES_USER=signal
POSTGRES_PASSWORD=signal
POSTGRES_DB=signal_lab
DATABASE_URL=postgresql://signal:signal@postgres:5432/signal_lab?schema=public

# Backend
PORT=3001
NODE_ENV=development
LOG_FILE_PATH=/var/log/signal-lab/backend.log
SENTRY_DSN=
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=signal-lab@0.1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
GRAFANA_INTERNAL_URL=http://grafana:3000

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
